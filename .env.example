# Canonical site URL (production). Example for GitHub Pages: https://<user>.github.io
APP_URL=https://lyminhnghia.github.io

# Static assets: add files under public/ — see @TODO in src/config/assets.ts (tech icons, duck sprite, UI sounds).

# shadcn registry namespace and JSON base URL (must match your deployment)
NEXT_PUBLIC_REGISTRY_NAMESPACE=@lyminhnghia
NEXT_PUBLIC_REGISTRY_NAMESPACE_URL=https://lyminhnghia.github.io/r/{name}.json

# Personal access token: https://github.com/settings/tokens
GITHUB_API_TOKEN=

# GitHub contributions graph API (third-party): https://github.com/grubersjoe/github-contributions-api
GITHUB_CONTRIBUTIONS_API_URL=https://github-contributions-api.jogruber.de

# Optional DMCA badge URL: https://www.dmca.com/ProtectionPro.aspx
NEXT_PUBLIC_DMCA_URL=https://www.dmca.com

# PostHog (optional analytics): https://us.posthog.com — replace ph.acme.com with your PostHog host if self-hosted
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://ph.acme.com
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.i.posthog.com

# OpenPanel (optional): https://dashboard.openpanel.dev
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=

# Google Tag Manager (optional): https://tagmanager.google.com
NEXT_PUBLIC_GTM_ID=GTM-XYZ
